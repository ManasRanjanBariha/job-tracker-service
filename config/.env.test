## Environment ##
NODE_ENV=test


## Server ##
PORT=4000
HOST=localhost


## Setup jet-logger ##
JET_LOGGER_MODE=console
JET_LOGGER_FILEPATH=jet-logger.log
JET_LOGGER_TIMESTAMP=true
JET_LOGGER_FORMAT=line

## JWT Configuration ##
JWT_SECRET=test_jwt_secret
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=test_refresh_secret
JWT_REFRESH_EXPIRATION=7d
